# Copie este arquivo para `.env` e preencha com suas credenciais SMTP.
# Se nao definir essas variaveis, o pipeline opera em modo DRY-RUN e
# apenas imprime no console como ficaria o email - util para validar
# a logica sem precisar de SMTP real.

# Exemplo para Gmail (use "senha de app" - app password):
CARDIOIA_SMTP_HOST=smtp.gmail.com
CARDIOIA_SMTP_PORT=587
CARDIOIA_SMTP_USER=seu_email@gmail.com
CARDIOIA_SMTP_PASS=sua_app_password_de_16_chars
CARDIOIA_ALERT_TO=medico_responsavel@hospital.com
